# Feature flags — set to "0" to disable, any other value (or unset) keeps the default ON.

# Sleep between requests (PRODUCT_DELAY / LISTING_DELAY + jitter).
# Disable only for offline testing against local HTML files.
SCRAPER_ENABLE_DELAYS=1

# Rotate the User-Agent string every 20–40 requests.
SCRAPER_ENABLE_UA_ROTATION=1

# Randomly inject a long "human stepped away" pause (1-in-25 chance, 90–240s).
SCRAPER_ENABLE_LONG_PAUSES=1

# Sleep 30–90 minutes after a CAPTCHA / block event before the next attempt.
# Set to 0 to raise CaptchaBlocked immediately instead (useful in scripts that
# manage their own retry / proxy-rotation logic).
SCRAPER_ENABLE_CAPTCHA_BACKOFF=1
